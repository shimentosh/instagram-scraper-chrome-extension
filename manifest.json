{
  "manifest_version": 3,
  "name": "Instagram Scraper - Posts, Hashtags & More",
  "version": "1.0",
  "description": "Free Instagram scraper. Export profiles, posts, followers, hashtags & comments to CSV or JSON instantly.",
  "permissions": ["sidePanel", "storage", "downloads", "tabs"],
  "host_permissions": ["*://*.instagram.com/*"],
  "icons": {
    "16": "icons/Logo.png",
    "48": "icons/Logo.png",
    "128": "icons/Logo.png"
  },
  "action": { "default_icon": "icons/Logo.png" },
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "popup.html" },
  "content_scripts": [
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
